// Test IDL — all supported constructs and types
// Used for testing the code generator

// ============================================================================
// Enums
// ============================================================================

enum Color : string {
  red,
  green,
  blue
}

enum Priority : string {
  low,
  medium,
  high,
  critical
}

// ============================================================================
// Mixins
// ============================================================================

mixin Identifiable {
  id: string;
  name: string = "";
}

mixin Timestamped {
  createdAt: int64;
  updatedAt: int64 = 0;
}

// ============================================================================
// Basic struct — all scalar types
// ============================================================================

struct ScalarTypes {
  .generate(parse, parse.verbose, serialize);
  fieldString: string;
  fieldBool: bool;
  fieldInt32: int32;
  fieldUint32: uint32;
  fieldInt64: int64;
  fieldUint64: uint64;
  fieldDouble: double;
}

// ============================================================================
// Optional scalars with defaults
// ============================================================================

struct ScalarDefaults {
  .generate(parse, parse.verbose, serialize);
  fieldString: string = "hello";
  fieldBool: bool = true;
  fieldInt32: int32 = -1;
  fieldUint32: uint32 = 42;
  fieldInt64: int64 = 0;
  fieldUint64: uint64 = 100;
  fieldDouble: double = 3.14;
  fieldNegDouble: double = -3.14;
}

// ============================================================================
// Chrono scalar types
// ============================================================================

struct ChronoFields {
  .generate(parse, parse.verbose, serialize);
  timeoutSec: chrono::seconds;
  retryMin: chrono::minutes = 5;
  ttlHours: chrono::hours;
}

// ============================================================================
// Mixed required and optional
// ============================================================================

struct MixedFields {
  .generate(parse, parse.verbose, serialize);
  required1: string;
  optional1: string = "";
  required2: int64;
  optional2: int64 = -1;
  required3: bool;
  optional3: bool = false;
}

// ============================================================================
// Nested structs
// ============================================================================

struct Inner {
  .generate(parse, parse.verbose, serialize);
  value: string;
  count: int64;
}

struct InnerWithComments {
  .generate(parse, parse.verbose, serialize);
  .extensions(comments);
  value: string;
  count: int64;
}

struct Outer {
  .generate(parse, parse.verbose, serialize);
  label: string;
  child: Inner;
}

struct OuterWithComments {
  .generate(parse, parse.verbose, serialize);
  .extensions(comments);
  label: string;
  child: Inner;
}

// ============================================================================
// Optional sub-objects
// ============================================================================

struct OptionalChildren {
  .generate(parse, parse.verbose, serialize);
  name: string;
  first: optional<Inner>;
  second: optional<Inner>;
}

// ============================================================================
// Arrays
// ============================================================================

struct ArrayFields {
  .generate(parse, parse.verbose, serialize);
  strings: [string];
  numbers: [int64];
  doubles: [double];
  items: [Inner];
}

// ============================================================================
// Optional arrays
// ============================================================================

struct OptionalArrays {
  .generate(parse, parse.verbose, serialize);
  label: string;
  tags: optional<[string]>;
  items: optional<[Inner]>;
}

// ============================================================================
// Nullable scalar/object-like shapes
// ============================================================================

struct NullableScalars {
  .generate(parse, parse.verbose, serialize);
  title: string;
  note: optional<string>(null_in=allow, empty_out=null);
  numbers: optional<[int64]>(null_in=allow, empty_out=null);
}

struct OptionalPolicyScalars {
  .generate(parse, parse.verbose, serialize);
  denyOmit: optional<string>;
  denyNull: optional<string>(empty_out=null);
  allowOmit: optional<string>(null_in=allow);
  allowNull: optional<string>(null_in=allow, empty_out=null);
  requiredNull: optional<string>(null_in=required, empty_out=null);
}

// ============================================================================
// Enum fields
// ============================================================================

struct WithEnum {
  .generate(parse, parse.verbose, serialize);
  color: Color;
  priority: Priority = "medium";
}

struct EnumArray {
  .generate(parse, parse.verbose, serialize);
  priorities: [Priority];
}

// ============================================================================
// Mixin usage
// ============================================================================

struct WithMixin {
  .generate(parse, parse.verbose, serialize);
  mixin Identifiable;
  value: double;
}

struct WithMultipleMixins {
  .generate(parse, parse.verbose, serialize);
  mixin Identifiable;
  mixin Timestamped;
  payload: string;
}

// ============================================================================
// Deep nesting
// ============================================================================

struct Level2 {
  .generate(parse, parse.verbose, serialize);
  value: int64;
}

struct Level1 {
  .generate(parse, parse.verbose, serialize);
  nested: Level2;
  items: [Level2];
}

struct Level0 {
  .generate(parse, parse.verbose, serialize);
  child: Level1;
  label: string = "";
}

// ============================================================================
// Usertypes and derived types
// ============================================================================

usertype plainVal("int64_t") include "testUserTypes.h";

derived testVal("int64_t", string, uint32) include "testDerivedTypes.h";
derived aVal("int64_t", string, uint32) include "testDerivedTypes.h";
derived bVal("int64_t", string, uint32) include "testDerivedTypes.h";
derived ctxCounter32Val("uint32_t", uint32, uint32) include "testDerivedTypes.h";

struct InlineMapped {
  .generate(parse, parse.verbose, serialize);
  amount: plainVal;
  optionalAmount: optional<plainVal>;
  nullableAmount: optional<plainVal>(null_in=allow, empty_out=null);
}

struct InlineMappedArray {
  .generate(parse, parse.verbose, serialize);
  amounts: [plainVal];
  optionalAmounts: optional<[plainVal]>;
  nullableAmounts: optional<[plainVal]>(null_in=allow, empty_out=null);
}

struct CtxChild {
  .generate(parse, serialize);
  value: testVal;
  label: string;
}

// Vector context: array of context-needing struct → vector<uint32_t>
struct CtxVectorParent {
  .generate(parse, serialize);
  items: [CtxChild];
}

struct CtxFixedArrayParent {
  .generate(parse, serialize);
  items: [CtxChild; 2];
}

struct CtxFixedMatrixParent {
  .generate(parse, serialize);
  grid: [[CtxChild; 2]; 2];
}

struct CtxDirectMappedArrayParent {
  .generate(parse, serialize);
  items: [testVal];
}

struct CtxNumericWireParent {
  .generate(parse, serialize);
  value: ctxCounter32Val;
}

// ============================================================================
// Usertypes with integer wire types
// ============================================================================

usertype counterVal("uint64_t") include "testUserTypes.h";
usertype counter32Val("uint32_t") include "testUserTypes.h";

struct WithUint64Mapped {
  .generate(parse, serialize);
  counter: counterVal;
}

struct WithUint32Mapped {
  .generate(parse, serialize);
  counter: counter32Val;
}

// ============================================================================
// Nullable struct object — emits null when absent
// ============================================================================

struct NullableObject {
  .generate(parse, parse.verbose, serialize);
  title: string;
  inner: optional<Inner>(null_in=allow, empty_out=null);
}

// ============================================================================
// Large enum (>4 values) — triggers perfect hash path
// ============================================================================

enum Status : string {
  pending,
  active,
  paused,
  completed,
  cancelled,
  failed
}

struct WithStatus {
  .generate(parse, parse.verbose, serialize);
  status: Status;
  label: string = "";
}

// ============================================================================
// Scalar context — parent with a single CtxChild (not array)
// ============================================================================

struct CtxScalarParent {
  .generate(parse, serialize);
  child: CtxChild;
}

struct CtxSplitAmountsParent {
  .generate(parse, serialize);
  leftAmounts: [testVal];
  rightAmounts: [testVal];
}

struct CtxSharedAmountsParent {
  .generate(parse, serialize);
  .ctxgroup(leftAmounts, rightAmounts);
  leftAmounts: [testVal];
  rightAmounts: [testVal];
}

struct CtxDuplicateMappedGroupsChild {
  .generate(parse, serialize);
  left: testVal;
  right: testVal;
}

struct CtxDuplicateMappedGroupsParent {
  .generate(parse, serialize, serialize.flat);
  child: CtxDuplicateMappedGroupsChild;
}

struct CtxMultipleDependenciesChild {
  .generate(parse, serialize);
  .ctxgroup(left, right);
  left: aVal;
  right: bVal;
}

struct CtxMultipleDependenciesParent {
  .generate(parse, serialize);
  child: CtxMultipleDependenciesChild;
}

// ============================================================================
// Chrono array (bug: chrono types in arrays not handled in parse codegen)
// ============================================================================

struct ChronoArray {
  .generate(parse, parse.verbose, serialize);
  durations: [chrono::seconds];
}

// ============================================================================
// Everything combined
// ============================================================================

struct Combined {
  .generate(parse, parse.verbose, serialize);
  mixin Identifiable;
  mixin Timestamped;
  priority: Priority = "low";
  active: bool;
  score: double = 0.0;
  metadata: optional<Inner>;
  tags: optional<[string]>;
  children: [Inner];
  nested: Outer;
}

// ============================================================================
// Flat serialize — no members, only static serialize
// ============================================================================

struct FlatResponse {
  .generate(serialize.flat);
  status: string;
  items: [Inner];
}

// ============================================================================
// Fixed-size arrays
// ============================================================================

struct FixedArrayScalar {
  .generate(parse, parse.verbose, serialize);
  coords: [double; 3];
  flags: [bool; 2];
}

struct FixedArrayStruct {
  .generate(parse, parse.verbose, serialize);
  pair: [Inner; 2];
}

struct OptionalFixedArray {
  .generate(parse, parse.verbose, serialize);
  label: string;
  data: optional<[int32; 3]>;
}

// ============================================================================
// Multi-dimensional arrays
// ============================================================================

struct Matrix2D {
  .generate(parse, parse.verbose, serialize);
  grid: [[int32]];
}

struct FixedMatrix {
  .generate(parse, parse.verbose, serialize);
  mat: [[double; 3]; 2];
}

struct MixedDims {
  .generate(parse, parse.verbose, serialize);
  rows: [[int32; 2]];
}

struct OptionalMatrix2D {
  .generate(parse, parse.verbose, serialize);
  label: string;
  grid: optional<[[int32]]>;
}

struct NullableMatrix2D {
  .generate(parse, parse.verbose, serialize);
  label: string;
  grid: optional<[[int32]]>(null_in=allow, empty_out=null);
}

struct OptionalFixedMatrix {
  .generate(parse, parse.verbose, serialize);
  label: string;
  mat: optional<[[double; 2]; 2]>;
}

// ============================================================================
// Variant fields
// ============================================================================

struct VariantScalars {
  .generate(parse, parse.verbose, serialize);
  value: variant(string, int64, bool);
}

struct VariantWithStruct {
  .generate(parse, parse.verbose, serialize);
  data: variant(Inner, string);
}

struct ShapeCircle {
  .generate(parse, parse.verbose, serialize);
  radius: double;
}

struct ShapeRect {
  .generate(parse, parse.verbose, serialize);
  width: double;
  height: double;
}

struct VariantMultiStruct {
  .generate(parse, parse.verbose, serialize);
  shape: variant(ShapeCircle, ShapeRect);
}

struct OptionalVariant {
  .generate(parse, parse.verbose, serialize);
  label: string;
  extra: optional<variant(string, int64)>;
}

struct VariantMappedString {
  .generate(parse, parse.verbose, serialize);
  data: variant(plainVal, bool);
}

struct VariantMappedUInt {
  .generate(parse, parse.verbose, serialize);
  data: variant(counterVal, bool);
}

struct VariantUInt64OrDouble {
  .generate(parse, parse.verbose, serialize);
  value: variant(uint64, double);
}

struct VariantMappedUIntOrDouble {
  .generate(parse, parse.verbose, serialize);
  value: variant(counterVal, double);
}

struct VariantTensorThenMatrix {
  .generate(parse, parse.verbose, serialize);
  value: variant([[[double]]], [[double]]);
}

struct VariantMatrixThenTensor {
  .generate(parse, parse.verbose, serialize);
  value: variant([[double]], [[[double]]]);
}

// Skip unknown fields
// ============================================================================

struct SkipUnknown {
  .generate(parse, parse.verbose, serialize);
  .flags(skip_unknown);
  value: string;
  count: int64;
}

// ============================================================================
// Keywords as field names
// ============================================================================

struct KeywordsAsFields {
  .generate(parse, serialize);
  type: string;
  context: int32;
  mapped: string;
  variant: bool;
  generate: int64;
  extensions: string;
  ctxgroup: double;
  flags: uint32;
  class: string;
  return: int32;
  class_: string;
  map: int64;
}

// ============================================================================
// Toplevel — single field parsed as top-level JSON value
// ============================================================================

struct TopLevelMap {
  .generate(parse, parse.verbose, serialize);
  .flags(toplevel);
  data: map<Inner>;
}

struct TopLevelArray {
  .generate(parse, parse.verbose, serialize);
  .flags(toplevel);
  items: [Inner];
}

struct TopLevelScalar {
  .generate(parse, parse.verbose, serialize);
  .flags(toplevel);
  value: double;
}

// ============================================================================
// Map fields
// ============================================================================

struct MapFields {
  .generate(parse, parse.verbose, serialize);
  label: string;
  scalarMap: map<double>;
  objectMap: map<Inner>;
  optionalScalarMap: optional<map<int64>>;
  optionalObjectMap: optional<map<Inner>>;
}

// ============================================================================
// Array layout — struct serialized as JSON array
// ============================================================================

struct ArrayLayoutAllRequired {
  .generate(parse, parse.verbose, serialize);
  .flags(array_layout);
  x: int32;
  y: int32;
  z: int32;
}

struct ArrayLayoutMixed {
  .generate(parse, parse.verbose, serialize);
  .flags(array_layout);
  name: string;
  count: int64;
  label: string = "default";
  score: double = 0.0;
  extra: optional<string>;
}

struct ArrayLayoutNested {
  .generate(parse, parse.verbose, serialize);
  .flags(array_layout);
  id: int64;
  child: Inner;
  items: [int64];
}

struct ArrayLayoutSkipExtra {
  .generate(parse, parse.verbose, serialize);
  .flags(array_layout, skip_unknown);
  a: string;
  b: int32;
}

struct ArrayLayoutAllDefaults {
  .generate(parse, parse.verbose, serialize);
  .flags(array_layout);
  x: int32 = 0;
  y: int32 = 0;
}

struct ArrayLayoutEnum {
  .generate(parse, parse.verbose, serialize);
  .flags(array_layout);
  color: Color;
  priority: Priority = "medium";
}

struct ArrayLayoutBarrier {
  .generate(parse, parse.verbose, serialize);
  .flags(array_layout);
  name: string;
  opt1: optional<string>;
  opt2: optional<string>(null_in=allow, empty_out=null);
}

// ============================================================================
// Typed array elements — optional, variant, map inside arrays
// ============================================================================

struct NullableElements {
  .generate(parse, parse.verbose, serialize);
  strings: [optional<string>];
  numbers: [optional<int64>];
  objects: [optional<Inner>];
  colors: [optional<Color>];
  denied: [optional<string>(null_in=deny)];
}

struct NullableElementCombos {
  .generate(parse, parse.verbose, serialize);
  optionalArray: optional<[optional<string>]>;
  fixedArray: [optional<int32>; 3];
  matrix: [[optional<int32>]];
}

struct VariantElements {
  .generate(parse, parse.verbose, serialize);
  scalars: [variant(string, int64)];
  mixed: [variant(Inner, string)];
}

struct MapElements {
  .generate(parse, parse.verbose, serialize);
  scalars: [map<int64>];
  objects: [map<Inner>];
}
