// Test IDL — all supported constructs and types
// Used for testing the code generator

// ============================================================================
// Enums
// ============================================================================

enum Color : string {
  red,
  green,
  blue
}

enum Priority : string {
  low,
  medium,
  high,
  critical
}

// ============================================================================
// Mixins
// ============================================================================

mixin Identifiable {
  id: string;
  name: string = "";
}

mixin Timestamped {
  createdAt: int64;
  updatedAt: int64 = 0;
}

// ============================================================================
// Basic struct — all scalar types
// ============================================================================

struct ScalarTypes {
  .generate(parse, parse.verbose, serialize);
  fieldString: string;
  fieldBool: bool;
  fieldInt32: int32;
  fieldUint32: uint32;
  fieldInt64: int64;
  fieldUint64: uint64;
  fieldDouble: double;
}

// ============================================================================
// Optional scalars with defaults
// ============================================================================

struct ScalarDefaults {
  .generate(parse, parse.verbose, serialize);
  fieldString: string = "hello";
  fieldBool: bool = true;
  fieldInt32: int32 = -1;
  fieldUint32: uint32 = 42;
  fieldInt64: int64 = 0;
  fieldUint64: uint64 = 100;
  fieldDouble: double = 3.14;
}

// ============================================================================
// Mixed required and optional
// ============================================================================

struct MixedFields {
  .generate(parse, parse.verbose, serialize);
  required1: string;
  optional1: string = "";
  required2: int64;
  optional2: int64 = -1;
  required3: bool;
  optional3: bool = false;
}

// ============================================================================
// Nested structs
// ============================================================================

struct Inner {
  .generate(parse, parse.verbose, serialize);
  value: string;
  count: int64;
}

struct Outer {
  .generate(parse, parse.verbose, serialize);
  label: string;
  child: Inner;
}

// ============================================================================
// Optional sub-objects
// ============================================================================

struct OptionalChildren {
  .generate(parse, parse.verbose, serialize);
  name: string;
  first: Inner?;
  second: Inner?;
}

// ============================================================================
// Arrays
// ============================================================================

struct ArrayFields {
  .generate(parse, parse.verbose, serialize);
  strings: [string];
  numbers: [int64];
  doubles: [double];
  items: [Inner];
}

// ============================================================================
// Optional arrays
// ============================================================================

struct OptionalArrays {
  .generate(parse, parse.verbose, serialize);
  label: string;
  tags: [string]?;
  items: [Inner]?;
}

// ============================================================================
// Enum fields
// ============================================================================

struct WithEnum {
  .generate(parse, parse.verbose, serialize);
  color: Color;
  priority: Priority = "medium";
}

// ============================================================================
// Mixin usage
// ============================================================================

struct WithMixin {
  .generate(parse, parse.verbose, serialize);
  mixin Identifiable;
  value: double;
}

struct WithMultipleMixins {
  .generate(parse, parse.verbose, serialize);
  mixin Identifiable;
  mixin Timestamped;
  payload: string;
}

// ============================================================================
// Deep nesting
// ============================================================================

struct Level2 {
  .generate(parse, parse.verbose, serialize);
  value: int64;
}

struct Level1 {
  .generate(parse, parse.verbose, serialize);
  nested: Level2;
  items: [Level2];
}

struct Level0 {
  .generate(parse, parse.verbose, serialize);
  child: Level1;
  label: string = "";
}

// ============================================================================
// Context — mapped type with context
// ============================================================================

mapped type testVal("int64_t") : string context(uint32) include "testMappedTypes.h";

struct CtxChild {
  .generate(parse, serialize);
  .context(testVal);
  value: testVal;
  label: string;
}

// Vector context: array of context-needing struct → vector<uint32_t>
struct CtxVectorParent {
  .generate(parse, serialize);
  items: [CtxChild];
}

// ============================================================================
// Everything combined
// ============================================================================

struct Combined {
  .generate(parse, parse.verbose, serialize);
  mixin Identifiable;
  mixin Timestamped;
  priority: Priority = "low";
  active: bool;
  score: double = 0.0;
  metadata: Inner?;
  tags: [string]?;
  children: [Inner];
  nested: Outer;
}

// ============================================================================
// Flat serialize — no members, only static serialize
// ============================================================================

struct FlatResponse {
  .generate(serialize.flat);
  status: string;
  items: [Inner];
}
