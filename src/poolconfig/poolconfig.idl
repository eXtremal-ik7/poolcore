// Pool configuration schema (pool.cfg.json)
// IDL for config file parsing with detailed error reporting
//
// Syntax:
//   field: type;              — required (error if missing)
//   field: type = default;    — optional with default value
//   field: optional<type>;    — std::optional, default null_in=deny, empty_out=omit
//   field: variant(a, b);     — variant type
//   [type]                    — array of type

// ============================================================================
// Root config
// ============================================================================

struct PoolFrontendConfig {
  .generate(parse.verbose);
  .extensions(comments);

  poolfrontend: FrontendSettings;
  coins: [CoinConfig];
  instances: [InstanceConfig];
}

// ============================================================================
// Frontend settings
// ============================================================================

struct FrontendSettings {
  .generate(parse.verbose);
  httpPort: uint32;
  workerThreadsNum: uint32 = 0;
  httpThreadsNum: uint32 = 0;
  adminPasswordHash: string = "";
  observerPasswordHash: string = "";
  dbPath: string;
  poolName: string;
  poolHostProtocol: string;
  poolHostAddress: string;
  poolActivateLinkPrefix: string;
  poolChangePasswordLinkPrefix: string;
  poolActivate2faLinkPrefix: string;
  poolDeactivate2faLinkPrefix: string;
  coinGeckoApiKey: string = "";
  smtpEnabled: bool;
  smtpServer: string;
  smtpLogin: string;
  smtpPassword: string;
  smtpSenderAddress: string;
  smtpUseSmtps: bool = false;
  smtpUseStartTLS: bool = true;
}

// ============================================================================
// Coin configuration
// ============================================================================

struct NodeConfig {
  .generate(parse.verbose);
  type: string;
  address: string;
  login: string = "";
  password: string = "";
  wallet: string = "";
  longPollEnabled: bool = true;
}

struct MiningAddressConfig {
  .generate(parse.verbose);
  address: string;
  privateKey: string = "";
  weight: uint32;
}

struct CoinConfig {
  .generate(parse.verbose);
  name: string;
  getWorkNodes: [NodeConfig];
  RPCNodes: [NodeConfig];
  requiredConfirmations: uint32;
  defaultPayoutThreshold: string;
  keepStatsTime: uint32;
  confirmationsCheckInterval: uint32;
  balanceCheckInterval: uint32;
  statisticCheckInterval: uint32;
  shareTarget: uint32;
  stratumWorkLifeTime: uint32 = 0;
  miningAddresses: [MiningAddressConfig];
  coinbaseMsg: string = "";
  profitSwitchCoeff: double = 0.0;
  ppsPayoutInterval: uint32 = 5;
  // ZEC specific
  poolZAddr: string = "";
  poolTAddr: string = "";
}

// ============================================================================
// Instance configuration
// ============================================================================

struct InstanceConfig {
  .generate(parse.verbose);
  name: string;
  type: string;
  protocol: string;
  backends: [string];
  port: uint32;
  shareDiff: double;
  versionMask: optional<string>;
  profitSwitcherEnabled: bool = false;
  resetWorkOnBlockChange: optional<[string]>;
  primaryBackends: optional<[string]>;
  secondaryBackends: optional<[string]>;
  fixedExtraNonceSize: optional<uint32>;
  mutableExtraNonceSize: optional<uint32>;
  // ZMQ-specific
  zmqWorkerPort: optional<uint32>;
  zmqHostName: optional<string>;
}
