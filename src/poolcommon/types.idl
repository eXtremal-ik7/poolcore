mapped type money("UInt<384>") : string context(uint32) include "poolcommon/mappedTypes.h";
mapped type moneyBTC("UInt<384>") : string include "poolcommon/mappedTypes.h";
mapped type unixTime("Timestamp") : int64 include "poolcommon/mappedTypes.h";
mapped type uint256("UInt<256>") : string include "poolcommon/mappedTypes.h";

enum MiningMode : string {
  pplns,
  pps
}

enum PayoutMode : string {
  disabled,
  regular,
  instant
}

enum SaturationFunction : string {
  none,
  tanh,
  clamp,
  cubic,
  softsign,
  norm,
  atan,
  exp
}

struct SettingsPayout {
  mode: PayoutMode = "disabled" @1;
  address: string = "" @2;
  instantPayoutThreshold: money @3;
}

struct SettingsMining {
  mode: MiningMode = "pplns" @1;
}

struct SettingsAutoExchange {
  payoutCoinName: string = "" @1;
}

struct UserFeePair {
  userId: string;
  percentage: double;
}

struct CoinFeeConfig {
  coinName: string;
  config: [UserFeePair];
}

struct ModeFeeConfig {
  default: [UserFeePair];
  coinSpecific: [CoinFeeConfig];
}

struct BackendPPS {
  enabled: bool = false @1;
  poolFee: double = 4.0 @2;
  saturationFunction: SaturationFunction = "none" @3;
  saturationB0: double = 0.0 @4;
  saturationANegative: double = 0.0 @5;
  saturationAPositive: double = 0.0 @6;
}

struct BackendSwap {
  acceptIncoming: bool = false @1;
  acceptOutgoing: bool = false @2;
}

struct BackendPayouts {
  .ctxgroup(instantMinimalPayout, regularMinimalPayout);

  instantPayoutsEnabled: bool = true @1;
  regularPayoutsEnabled: bool = true @2;
  instantMinimalPayout: money @3;
  instantPayoutInterval: chrono::minutes = 1 @4;
  regularMinimalPayout: money @5;
  regularPayoutInterval: chrono::hours = 24 @6;
  regularPayoutDayOffset: chrono::hours = 0 @7;
}

struct PPSBalanceSnapshot {
  balance: money;
  totalBlocksFound: double = 0.0;
  time: unixTime;
}

struct PPSState {
  .ctxgroup(balance, referenceBalance, lastBaseBlockReward, min, max, lastAverageTxFee);
  // Pool-side PPS balance: increases when block found (PPS correction from PPLNS),
  // decreases when PPS rewards are accrued to users.
  // Can go negative — that's the pool's risk.
  balance: money;
  // Reference PPS balance: tracks pure PPS risk without pool fee profit.
  // Increases by full block reward on block found, decreases by full share cost
  // (before pool fee deduction). Used for saturation coefficient and min/max tracking.
  referenceBalance: money;
  // Base reward of the last known block (subsidy without tx fees, fixed-point 128.256)
  lastBaseBlockReward: money;
  // Fractional count of blocks found (only PPS portion of each block)
  totalBlocksFound: double = 0.0;
  // Fractional count of orphan blocks (PPS portion)
  orphanBlocks: double = 0.0;
  min: PPSBalanceSnapshot;
  max: PPSBalanceSnapshot;
  // Last applied saturation coefficient (1.0 = no correction)
  lastSaturateCoeff: double = 1.0;
  // Last average transaction fee per block (fixed-point 128.256)
  lastAverageTxFee: money;
  // Timestamp of this snapshot (used as kvdb key for history)
  time: unixTime;

  cpp {
    enum { CurrentRecordVersion = 1 };
    static double balanceInBlocks(const UInt<384> &balance, const UInt<384> &baseBlockReward);
    static double sqLambda(const UInt<384> &balance, const UInt<384> &baseBlockReward, double totalBlocksFound);
    void updateMinMax(Timestamp now);
    std::string getPartitionId() const;
    void serializeKey(class xmstream &stream) const;
    void serializeValue(class xmstream &stream) const;
    bool deserializeValue(const void *data, size_t size);
  }
}

struct RoundBestShareData {
  hash: optional<uint256>;
  shareDifficulty: double = 0.0;
  blockDifficulty: double = 0.0;
  expectedWork: uint256;
  time: unixTime;

  cpp {
    bool hasShare() const { return ShareDifficulty > 0.0; }
    void reset() { *this = CRoundBestShareData(); }
  }
}

struct CoinGeckoPrice {
  .generate(parse);
  .flags(skip_unknown);
  usd: double = 0;
}

struct CoinGeckoPrices {
  .generate(parse);
  .flags(toplevel);
  data: map<CoinGeckoPrice>;
}

struct MergedBlockInfo {
  coin: string;
  height: int64;
  hash: string;
}

struct PPLNSPayoutEntry {
  startTime: unixTime;
  endTime: unixTime;
  hash: string;
  height: int64;
  value: money;
  valueBTC: moneyBTC;
  valueUSD: moneyBTC;
}

struct PPSPayoutEntry {
  startTime: unixTime;
  endTime: unixTime;
  value: money;
  valueBTC: moneyBTC;
  valueUSD: moneyBTC;
}

struct AccumulatedPayoutEntry {
  timeLabel: int64;
  value: money;
  valueBTC: moneyBTC;
  valueUSD: moneyBTC;

  cpp {
    void merge(const UInt<384> &payoutValue, double rateToBTC, double rateBTCToUSD, unsigned fractionalPartSize);
    void mergeScaled(const UInt<384> &payoutValue, double rateToBTC, double rateBTCToUSD, double coeff, unsigned fractionalPartSize);
  }
}
