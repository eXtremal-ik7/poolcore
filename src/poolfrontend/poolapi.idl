// --- backendQueryCoins ---
struct BackendQueryCoinsRequest {
  .generate(parse);
}

struct HttpCoinInfo {
  .generate(serialize);
  name: string;
  fullName: string;
  algorithm: string;
  ppsAvailable: bool;
  pplnsFee: double;
  ppsFee: double;
  minimalRegularPayout: string;
  minimalInstantPayout: string;
  acceptIncoming: bool;
  acceptOutgoing: bool;
  valueBTC: optional<double>(null_in=allow, empty_out=null);
  valueUSD: optional<double>(null_in=allow, empty_out=null);
  height: optional<int64>(null_in=allow, empty_out=null);
  difficulty: optional<double>(null_in=allow, empty_out=null);
  powerUnit: optional<string>(null_in=allow, empty_out=null);
  powerMultLog10: optional<int64>(null_in=allow, empty_out=null);
  powerPPS: optional<int64>(null_in=allow, empty_out=null);
  dailyPPS: optional<string>(null_in=allow, empty_out=null);
  dailyPPSUSD: optional<string>(null_in=allow, empty_out=null);
  dailyPPSBTC: optional<string>(null_in=allow, empty_out=null);
}

struct BackendQueryCoinsResponse {
  .generate(serialize.flat);
  status: string;
  coins: [HttpCoinInfo];
}

