// --- backendGetPPSState ---
// → SessionCoinRequest

struct PPSBalanceInfo {
  .generate(serialize);
  value: string;
  inBlocks: double;
}

struct PPSBalanceWithSqLambda {
  .generate(serialize);
  value: string;
  inBlocks: double;
  sqLambda: double;
}

struct HttpPPSBalanceSnapshot {
  .generate(serialize);
  time: int64;
  value: string;
  inBlocks: double;
  sqLambda: double;
}

struct HttpPPSState {
  .generate(serialize);
  time: int64;
  balance: PPSBalanceInfo;
  refBalance: PPSBalanceWithSqLambda;
  minRefBalance: HttpPPSBalanceSnapshot;
  maxRefBalance: HttpPPSBalanceSnapshot;
  totalBlocksFound: double;
  orphanBlocks: double;
  lastSaturateCoeff: double;
  lastBaseBlockReward: string;
  lastAverageTxFee: string;

  cpp {
    CHttpPPSState() = default;
    CHttpPPSState(const CPPSState &pps, unsigned fractionalPartSize);
  }
}

struct BackendGetPPSStateResponse {
  .generate(serialize.flat);
  status: string;
  state: HttpPPSState;
}

// --- backendQueryPPSHistory ---
struct BackendQueryPPSHistoryRequest {
  .generate(parse);
  id: string;
  coin: string;
  timeFrom: int64;
  timeTo: int64;
}
struct BackendQueryPPSHistoryResponse {
  .generate(serialize.flat);
  status: string;
  history: [HttpPPSState];
}

// --- backendPoolLuck ---
struct BackendPoolLuckRequest {
  .generate(parse);
  coin: string;
  intervals: [int64];
}
struct BackendPoolLuckResponse {
  .generate(serialize.flat);
  status: string;
  luck: [double];
}

// ============================================================================
// Instance queries
// ============================================================================

// --- instanceEnumerateAll ---
struct InstanceInfo {
  .generate(serialize);
  protocol: string;
  type: string;
  port: int64;
  backends: [string];
  shareDiff: optional<double>;  // only for protocol == "stratum"
}

struct InstanceEnumerateAllResponse {
  .generate(serialize.flat);
  status: string;
  instances: [InstanceInfo];
}

// ============================================================================
// Complex mining stats
// ============================================================================

// --- complexMiningStatsGetInfo ---
// Response is opaque (forwarded from ComplexMiningStats engine)
// → SessionRequest
