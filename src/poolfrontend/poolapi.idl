// --- backendGetConfig ---
// → SessionCoinRequest
struct BackendGetConfigResponse {
  status: string;
  pps: BackendPPS;
  payouts: BackendPayouts;
  swap: BackendSwap;
  saturationFunctions: [string];
}

// --- backendUpdateConfig ---
struct BackendUpdateConfigRequest {
  id: string;
  coin: string;
  pps: BackendPPS?;
  payouts: BackendPayouts?;
  swap: BackendSwap?;
}

// --- backendGetPPSState ---
// → SessionCoinRequest

struct PPSBalanceInfo {
  value: string;
  inBlocks: double;
}

struct PPSBalanceWithSqLambda {
  value: string;
  inBlocks: double;
  sqLambda: double;
}

struct HttpPPSBalanceSnapshot {
  time: int64;
  value: string;
  inBlocks: double;
  sqLambda: double;
}

struct HttpPPSState {
  time: int64;
  balance: PPSBalanceInfo;
  refBalance: PPSBalanceWithSqLambda;
  minRefBalance: HttpPPSBalanceSnapshot;
  maxRefBalance: HttpPPSBalanceSnapshot;
  totalBlocksFound: double;
  orphanBlocks: double;
  lastSaturateCoeff: double;
  lastBaseBlockReward: string;
  lastAverageTxFee: string;

  cpp {
    CHttpPPSState() = default;
    CHttpPPSState(const CPPSState &pps, unsigned fractionalPartSize);
  }
}

struct BackendGetPPSStateResponse {
  status: string;
  state: HttpPPSState;
}

// --- backendQueryPPSHistory ---
struct BackendQueryPPSHistoryRequest {
  id: string;
  coin: string;
  timeFrom: int64;
  timeTo: int64;
}
struct BackendQueryPPSHistoryResponse {
  status: string;
  history: [HttpPPSState];
}

// --- backendPoolLuck ---
struct BackendPoolLuckRequest {
  coin: string;
  intervals: [int64];
}
struct BackendPoolLuckResponse {
  status: string;
  luck: [double];
}

// ============================================================================
// Instance queries
// ============================================================================

// --- instanceEnumerateAll ---
struct InstanceInfo {
  protocol: string;
  type: string;
  port: int64;
  backends: [string];
  shareDiff: double?;           // only for protocol == "stratum"
}

struct InstanceEnumerateAllResponse {
  status: string;
  instances: [InstanceInfo];
}

